{
    "version": 2,
    "builds": [
          {
                  "src": "client/index.html",
                  "use": "@vercel/static-build",
                  "config": { "distDir": "client/dist" }
          },
          {
                  "src": "server/_core/index.ts",
                  "use": "@vercel/node",
                  "config": { "includeFiles": ["server/**", "dist/**"] }
          }
    ],
    "routes": [
          {
                  "src": "/api/(.*)",
                  "dest": "server/_core/index.ts"
          },
          {
                  "src": "/(.*)",
                  "dest": "client/dist/index.html"
          }
    ]
}
